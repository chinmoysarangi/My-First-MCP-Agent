{
  "mcp": {
    "allowed": ["tavily", "filesystem"]
  },
  "mcpServers": {
    "tavily": {
  		"command": "npx",
			"args": [
        "-y",
        "tavily-mcp"
      ],
      "env": {
        "TAVILY_API_KEY": "YOUR_TAVILY_API_KEY_HERE"
      }
    },
    "filesystem": {
      "command": "npx.cmd",
      "args": 
      [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\%USERPROFILE%\\Documents\\PROJECT_NAME"
      ]
    }
  },
  "excludeTools": ["google_search"]
}